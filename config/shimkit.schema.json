    "VersionConstraint": {
      "additionalProperties": false,
      "description": "User-declarable acceptable-range for one external tool.\n\n`min` / `max` accept either a bare version (interpreted as `>=`\n/ `<=`) or an explicit specifier (e.g. ``\"<25.0\"``). `preferred`\nis informational only.",
      "properties": {
        "min": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Min"
        },
        "max": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Max"
        },
        "preferred": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Preferred"
        }
      },
      "title": "VersionConstraint",
      "type": "object"
    },
    "VersionsConfig": {
      "additionalProperties": false,
