      "additionalProperties": false,
      "properties": {
        "rc_file": {
          "description": "Primary rc file relative to $HOME",
          "title": "Rc File",
          "type": "string"
        },
        "fallback_rc": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Fallback rc file when primary is absent",
          "title": "Fallback Rc"
        }
      },
      "required": [
        "rc_file"
      ],
      "title": "ShellConfigEntry",
      "type": "object"
    },
    "ShellToolConfig": {
      "additionalProperties": false,
      "properties": {
        "supported_shells": {
          "items": {
            "type": "string"
          },
          "title": "Supported Shells",
          "type": "array"
        },
        "config_map": {
          "additionalProperties": {
            "$ref": "#/$defs/ShellConfigEntry"
          },
          "title": "Config Map",
          "type": "object"
        }
      },
      "required": [
        "supported_shells",
        "config_map"
      ],
      "title": "ShellToolConfig",
      "type": "object"
    },
    "SshConfig": {
