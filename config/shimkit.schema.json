{
  "$defs": {
    "AdGuardConfig": {
      "additionalProperties": false,
      "description": "AdGuard Home port-conflict fixer — `shimkit adguard`.",
      "properties": {
        "install_candidates": {
          "items": {
            "type": "string"
          },
          "title": "Install Candidates",
          "type": "array"
        },
        "default_remap_dns_port": {
          "default": 5353,
          "maximum": 65535,
          "minimum": 1,
          "title": "Default Remap Dns Port",
          "type": "integer"
        },
        "default_remap_http_port": {
          "default": 8080,
          "maximum": 65535,
          "minimum": 1,
          "title": "Default Remap Http Port",
          "type": "integer"
        },
        "target_ports": {
          "items": {
            "$ref": "#/$defs/AdGuardTargetPort"
          },
          "title": "Target Ports",
          "type": "array"
        },
        "safe_units_to_stop": {
          "items": {
            "type": "string"
          },
          "title": "Safe Units To Stop",
          "type": "array"
        },
        "pihole_unit": {
          "default": "pihole-FTL.service",
          "title": "Pihole Unit",
          "type": "string"
        },
        "resolv_conf_mode": {
          "default": "symlink",
          "enum": [
            "symlink",
            "static"
          ],
          "title": "Resolv Conf Mode",
          "type": "string"
        },
        "prefer_api_over_yaml": {
          "default": true,
          "title": "Prefer Api Over Yaml",
          "type": "boolean"
        },
        "api_base_url": {
          "default": "http://127.0.0.1:80",
          "title": "Api Base Url",
          "type": "string"
        }
      },
      "title": "AdGuardConfig",
      "type": "object"
    },
    "AdGuardTargetPort": {
      "additionalProperties": false,
      "description": "One row in `tools.adguard.target_ports`.",
      "properties": {
        "port": {
          "maximum": 65535,
          "minimum": 1,
          "title": "Port",
          "type": "integer"
        },
        "proto": {
          "enum": [
            "tcp",
            "udp"
          ],
          "title": "Proto",
          "type": "string"
        },
        "role": {
          "description": "Human-readable role label, e.g. 'DNS'",
          "title": "Role",
          "type": "string"
        }
      },
      "required": [
        "port",
        "proto",
        "role"
      ],
      "title": "AdGuardTargetPort",
      "type": "object"
    },
    "BrewConfig": {
      "additionalProperties": false,
      "properties": {
        "install_url": {
          "default": "https://raw.githubusercontent.com/Homebrew/install/97a0b89e0cfce05ce1806c8f9ebc7b3f1813589e/install.sh",
          "title": "Install Url",
          "type": "string"
        }
      },
      "title": "BrewConfig",
      "type": "object"
    },
    "CronConfig": {
      "additionalProperties": false,
      "description": "`shimkit cron` — generic user-crontab editor.",
      "properties": {
        "managed_prefix": {
          "default": "# shimkit:",
          "title": "Managed Prefix",
          "type": "string"
        },
        "backup_dir": {
          "default": "~/.shimkit/data/cron",
          "title": "Backup Dir",
          "type": "string"
        },
        "max_managed_entries": {
          "default": 200,
          "maximum": 10000,
          "minimum": 1,
          "title": "Max Managed Entries",
          "type": "integer"
        }
      },
      "title": "CronConfig",
      "type": "object"
    },
    "DbConfig": {
      "additionalProperties": false,
      "description": "`shimkit db` — container-first database orchestration.",
      "properties": {
        "default_volume_root": {
          "default": "~/.shimkit/data/db",
          "title": "Default Volume Root",
          "type": "string"
        },
        "default_bind_host": {
          "default": "127.0.0.1",
          "title": "Default Bind Host",
          "type": "string"
        },
        "default_id": {
          "default": "dev",
          "title": "Default Id",
          "type": "string"
        },
        "default_password": {
          "default": "shimkit-dev",
          "title": "Default Password",
          "type": "string"
        },
        "reset_severe_token": {
          "default": "RESET-DB",
          "title": "Reset Severe Token",
          "type": "string"
        },
        "engines": {
          "additionalProperties": {
            "$ref": "#/$defs/DbEngineEntry"
          },
          "title": "Engines",
          "type": "object"
        },
        "host_services": {
          "additionalProperties": {
            "$ref": "#/$defs/DbHostServiceEntry"
          },
          "title": "Host Services",
          "type": "object"
        }
      },
      "title": "DbConfig",
      "type": "object"
    },
    "DbEngineEntry": {
      "additionalProperties": false,
      "description": "Per-engine container settings — image + default port.",
      "properties": {
        "image": {
          "title": "Image",
          "type": "string"
        },
        "default_port": {
          "maximum": 65535,
          "minimum": 1,
          "title": "Default Port",
          "type": "integer"
        }
      },
      "required": [
        "image",
        "default_port"
      ],
      "title": "DbEngineEntry",
      "type": "object"
    },
    "DbHostServiceEntry": {
      "additionalProperties": false,
      "description": "Per-engine service-name mapping for `--on-host` mode.\n\nLinux assumes systemd unit names; macOS assumes the literal\n`brew services` formula name. Override per-install when your\ndistro or formula uses a different name.",
      "properties": {
        "service_linux": {
          "title": "Service Linux",
          "type": "string"
        },
        "service_macos": {
          "title": "Service Macos",
          "type": "string"
        }
      },
      "required": [
        "service_linux",
        "service_macos"
      ],
      "title": "DbHostServiceEntry",
      "type": "object"
    },
    "DnsConfig": {
      "additionalProperties": false,
      "description": "macOS DNS recovery tool — `shimkit dns`.",
      "properties": {
        "test_domains": {
          "items": {
            "type": "string"
          },
          "title": "Test Domains",
          "type": "array"
        },
        "dns_servers": {
          "additionalProperties": {
            "items": {
              "type": "string"
            },
            "type": "array"
          },
          "title": "Dns Servers",
          "type": "object"
        },
        "step_timeout_seconds": {
          "default": 5,
          "maximum": 60,
          "minimum": 1,
          "title": "Step Timeout Seconds",
          "type": "integer"
        },
        "nuclear_confirm_token": {
          "default": "REGENERATE",
          "title": "Nuclear Confirm Token",
          "type": "string"
        },
        "reset_confirm_token": {
          "default": "RESET",
          "title": "Reset Confirm Token",
          "type": "string"
        },
        "backup_dir": {
          "default": "~/Library/Application Support/shimkit/dns-backups",
          "title": "Backup Dir",
          "type": "string"
        }
      },
      "title": "DnsConfig",
      "type": "object"
    },
    "DockerCleanConfig": {
      "additionalProperties": false,
      "description": "Docker resource cleanup — `shimkit docker-clean`.",
      "properties": {
        "nuke_confirm_token": {
          "default": "DELETE",
          "title": "Nuke Confirm Token",
          "type": "string"
        },
        "kubernetes_image_patterns": {
          "items": {
            "type": "string"
          },
          "title": "Kubernetes Image Patterns",
          "type": "array"
        },
        "daemon_verify_timeout_seconds": {
          "default": 30,
          "maximum": 300,
          "minimum": 1,
          "title": "Daemon Verify Timeout Seconds",
          "type": "integer"
        },
        "default_buildx_prune_all": {
          "default": true,
          "title": "Default Buildx Prune All",
          "type": "boolean"
        }
      },
      "title": "DockerCleanConfig",
      "type": "object"
    },
    "EnvConfig": {
      "additionalProperties": false,
      "description": "`.env` viewer + scaffolder — `shimkit env`.",
      "properties": {
        "redact_pattern": {
          "default": "password|passwd|pwd|secret|token|api[_-]?key|authorization|key|credential",
          "title": "Redact Pattern",
          "type": "string"
        },
        "default_search_paths": {
          "items": {
            "type": "string"
          },
          "title": "Default Search Paths",
          "type": "array"
        }
      },
      "title": "EnvConfig",
      "type": "object"
    },
    "FrameworkConfig": {
      "additionalProperties": false,
      "description": "Parent for the `shimkit framework *` family of tools.",
      "properties": {
        "laravel": {
          "$ref": "#/$defs/FrameworkLaravelConfig"
        },
        "symfony": {
          "$ref": "#/$defs/FrameworkSymfonyConfig"
        },
        "django": {
          "$ref": "#/$defs/FrameworkDjangoConfig"
        }
      },
      "title": "FrameworkConfig",
      "type": "object"
    },
    "FrameworkDjangoConfig": {
      "additionalProperties": false,
      "description": "`shimkit framework django` — Django-specific helpers (v0.16.0+).",
      "properties": {
        "web_group": {
          "default": "www-data",
          "title": "Web Group",
          "type": "string"
        },
        "file_mode": {
          "default": "664",
          "title": "File Mode",
          "type": "string"
        },
        "dir_mode": {
          "default": "775",
          "title": "Dir Mode",
          "type": "string"
        },
        "writable_dirs": {
          "items": {
            "type": "string"
          },
          "title": "Writable Dirs",
          "type": "array"
        },
        "default_debug": {
          "default": true,
          "title": "Default Debug",
          "type": "boolean"
        }
      },
      "title": "FrameworkDjangoConfig",
      "type": "object"
    },
    "FrameworkLaravelConfig": {
      "additionalProperties": false,
      "description": "`shimkit framework laravel` — Laravel-specific helpers.",
      "properties": {
        "web_group": {
          "default": "www-data",
          "title": "Web Group",
          "type": "string"
        },
        "file_mode": {
          "default": "664",
          "title": "File Mode",
          "type": "string"
        },
        "dir_mode": {
          "default": "775",
          "title": "Dir Mode",
          "type": "string"
        },
        "writable_dirs": {
          "items": {
            "type": "string"
          },
          "title": "Writable Dirs",
          "type": "array"
        },
        "default_cron_schedule": {
          "default": "* * * * *",
          "title": "Default Cron Schedule",
          "type": "string"
        }
      },
      "title": "FrameworkLaravelConfig",
      "type": "object"
    },
    "FrameworkSymfonyConfig": {
      "additionalProperties": false,
      "description": "`shimkit framework symfony` — Symfony-specific helpers (v0.14.0+).",
      "properties": {
        "web_group": {
          "default": "www-data",
          "title": "Web Group",
          "type": "string"
        },
        "file_mode": {
          "default": "664",
          "title": "File Mode",
          "type": "string"
        },
        "dir_mode": {
          "default": "775",
          "title": "Dir Mode",
          "type": "string"
        },
        "writable_dirs": {
          "items": {
            "type": "string"
          },
          "title": "Writable Dirs",
          "type": "array"
        },
        "default_env": {
          "default": "dev",
          "title": "Default Env",
          "type": "string"
        }
      },
      "title": "FrameworkSymfonyConfig",
      "type": "object"
    },
    "GpgConfig": {
      "additionalProperties": false,
      "description": "GPG key + git-signing hygiene — `shimkit gpg`.",
      "properties": {
        "default_key_type": {
          "default": "ed25519",
          "title": "Default Key Type",
          "type": "string"
        },
        "default_key_expiry": {
          "default": "1y",
          "title": "Default Key Expiry",
          "type": "string"
        }
      },
      "title": "GpgConfig",
      "type": "object"
    },
    "HostsConfig": {
      "additionalProperties": false,
      "description": "/etc/hosts editor — `shimkit hosts`.",
      "properties": {
        "hosts_path": {
          "default": "/etc/hosts",
          "title": "Hosts Path",
          "type": "string"
        },
        "apply_list_severe_token": {
          "default": "APPLY-LIST",
          "title": "Apply List Severe Token",
          "type": "string"
        },
        "max_entries_per_apply": {
          "default": 5000,
          "maximum": 1000000,
          "minimum": 1,
          "title": "Max Entries Per Apply",
          "type": "integer"
        },
        "managed_block_marker": {
          "default": "# === shimkit-managed ===",
          "title": "Managed Block Marker",
          "type": "string"
        }
      },
      "title": "HostsConfig",
      "type": "object"
    },
    "JavaConfig": {
      "additionalProperties": false,
      "properties": {
        "default_version": {
          "default": 21,
          "title": "Default Version",
          "type": "integer"
        },
        "supported_versions": {
          "items": {
            "$ref": "#/$defs/JavaVersionEntry"
          },
          "title": "Supported Versions",
          "type": "array"
        },
        "scan_paths": {
          "$ref": "#/$defs/JavaScanPaths"
        },
        "oracle_glob_patterns": {
          "items": {
            "type": "string"
          },
          "title": "Oracle Glob Patterns",
          "type": "array"
        },
        "oracle_safe_roots": {
          "items": {
            "type": "string"
          },
          "title": "Oracle Safe Roots",
          "type": "array"
        }
      },
      "required": [
        "supported_versions"
      ],
      "title": "JavaConfig",
      "type": "object"
    },
    "JavaScanPaths": {
      "additionalProperties": false,
      "properties": {
        "macos": {
          "items": {
            "type": "string"
          },
          "title": "Macos",
          "type": "array"
        },
        "linux": {
          "items": {
            "type": "string"
          },
          "title": "Linux",
          "type": "array"
        },
        "container": {
          "items": {
            "type": "string"
          },
          "title": "Container",
          "type": "array"
        }
      },
      "title": "JavaScanPaths",
      "type": "object"
    },
    "JavaVersionEntry": {
      "additionalProperties": false,
      "properties": {
        "major": {
          "description": "Major Java version, e.g. 21",
          "maximum": 99,
          "minimum": 1,
          "title": "Major",
          "type": "integer"
        },
        "label": {
          "description": "Short label shown next to the version",
          "title": "Label",
          "type": "string"
        },
        "brew_formula": {
          "description": "Homebrew formula, e.g. openjdk@21",
          "title": "Brew Formula",
          "type": "string"
        },
        "lts": {
          "default": false,
          "title": "Lts",
          "type": "boolean"
        },
        "recommended": {
          "default": false,
          "title": "Recommended",
          "type": "boolean"
        },
        "deprecated": {
          "default": false,
          "title": "Deprecated",
          "type": "boolean"
        }
      },
      "required": [
        "major",
        "label",
        "brew_formula"
      ],
      "title": "JavaVersionEntry",
      "type": "object"
    },
    "LempConfig": {
      "additionalProperties": false,
      "description": "`shimkit stack lemp` — three-container LEMP recipe.",
      "properties": {
        "nginx_image": {
          "default": "nginx:1.27-alpine",
          "title": "Nginx Image",
          "type": "string"
        },
        "php_fpm_image": {
          "default": "php:8.3-fpm",
          "title": "Php Fpm Image",
          "type": "string"
        },
        "default_port": {
          "default": 18080,
          "maximum": 65535,
          "minimum": 1,
          "title": "Default Port",
          "type": "integer"
        },
        "default_db": {
          "default": "mysql",
          "title": "Default Db",
          "type": "string"
        }
      },
      "title": "LempConfig",
      "type": "object"
    },
    "LogsConfig": {
      "additionalProperties": false,
      "description": "System-log tail/grep — `shimkit logs`.",
      "properties": {
        "default_lines": {
          "default": 100,
          "maximum": 100000,
          "minimum": 1,
          "title": "Default Lines",
          "type": "integer"
        },
        "max_grep_lines": {
          "default": 5000,
          "maximum": 1000000,
          "minimum": 1,
          "title": "Max Grep Lines",
          "type": "integer"
        }
      },
      "title": "LogsConfig",
      "type": "object"
    },
    "PackageManagerEntry": {
      "additionalProperties": false,
      "properties": {
        "install_cmd": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "items": {
                "type": "string"
              },
              "type": "array"
            }
          ],
          "title": "Install Cmd"
        },
        "update_cmd": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "items": {
                "type": "string"
              },
              "type": "array"
            }
          ],
          "title": "Update Cmd"
        },
        "upgrade_cmd": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "items": {
                "type": "string"
              },
              "type": "array"
            }
          ],
          "title": "Upgrade Cmd"
        },
        "platforms": {
          "items": {
            "enum": [
              "macos",
              "linux"
            ],
            "type": "string"
          },
          "title": "Platforms",
          "type": "array"
        }
      },
      "required": [
        "install_cmd",
        "update_cmd",
        "upgrade_cmd",
        "platforms"
      ],
      "title": "PackageManagerEntry",
      "type": "object"
    },
    "PackageManagersConfig": {
      "additionalProperties": false,
      "properties": {
        "preference_order": {
          "items": {
            "type": "string"
          },
          "title": "Preference Order",
          "type": "array"
        },
        "definitions": {
          "additionalProperties": {
            "$ref": "#/$defs/PackageManagerEntry"
          },
          "title": "Definitions",
          "type": "object"
        }
      },
      "required": [
        "preference_order",
        "definitions"
      ],
      "title": "PackageManagersConfig",
      "type": "object"
    },
    "PortsConfig": {
      "additionalProperties": false,
      "description": "Port owner inspection + killer — `shimkit ports`.",
      "properties": {
        "default_signal": {
          "default": "TERM",
          "title": "Default Signal",
          "type": "string"
        },
        "init_pid_severe_token": {
          "default": "KILL-INIT",
          "title": "Init Pid Severe Token",
          "type": "string"
        },
        "system_pid_threshold": {
          "default": 100,
          "maximum": 65535,
          "minimum": 1,
          "title": "System Pid Threshold",
          "type": "integer"
        }
      },
      "title": "PortsConfig",
      "type": "object"
    },
    "SelfUpdateConfig": {
      "additionalProperties": false,
      "properties": {
        "enabled": {
          "default": true,
          "title": "Enabled",
          "type": "boolean"
        },
        "check_on_startup": {
          "default": true,
          "title": "Check On Startup",
          "type": "boolean"
        },
        "github_repo": {
          "default": "simtabi/shimkit",
          "title": "Github Repo",
          "type": "string"
        }
      },
      "title": "SelfUpdateConfig",
      "type": "object"
    },
